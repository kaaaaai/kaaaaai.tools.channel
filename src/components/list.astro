---
import Layout from '../layouts/base.astro'
import Header from '../components/header.astro'
import Item from '../components/item.astro'

const { SITE_URL } = Astro.locals
const { channel, before = true, after = true, isItem = false, pageHeading, pageSeo } = Astro.props
const posts = channel.posts ?? []

const beforeCursor = posts[posts.length - 1]?.id
const afterCursor = posts[0]?.id
const hasOlderPosts = before && beforeCursor && Number(beforeCursor) > 1
const hasNewerPosts = after && afterCursor
const itemsClass = 'mt-0 mb-0 ml-0 flex list-none flex-col gap-5 pl-0 md:gap-6'
const paginationClass = 'mt-8 flex items-center justify-between border-t border-line/70 pt-4'
const paginationLinkClass =
  'inline-flex min-h-10 items-center justify-center gap-2 border-b border-line/80 bg-transparent px-0 py-1 text-sm font-medium leading-none text-muted no-underline transition-[color,border-color] hover:border-accent/30 hover:text-accent hover:no-underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-heading'
const paginationNewerClass = 'ml-auto'
---

<Layout channel={channel} seo={pageSeo}>
  {pageHeading ? <h1 class="sr-only">{pageHeading}</h1> : null}
  <slot name="header">
    <Header channel={channel} />
  </slot>
  <ol class={itemsClass} aria-label={isItem ? 'Post' : 'Posts'}>
    {
      posts.map((post) => (
        <li>
          <Item post={post} isItem={isItem} />
        </li>
      ))
    }
  </ol>

  {
    hasOlderPosts || hasNewerPosts ? (
      <nav class={paginationClass} aria-label="Pagination">
        {hasOlderPosts ? (
          <a
            href={`${SITE_URL}before/${beforeCursor}`}
            title="Older posts"
            aria-label="Older posts"
            class={paginationLinkClass}
          >
            <span aria-hidden="true">←</span>
            <span>Older</span>
          </a>
        ) : null}
        {hasNewerPosts ? (
          <a
            href={`${SITE_URL}after/${afterCursor}`}
            title="Newer posts"
            aria-label="Newer posts"
            class:list={[paginationLinkClass, paginationNewerClass]}
          >
            <span>Newer</span>
            <span aria-hidden="true">→</span>
          </a>
        ) : null}
      </nav>
    ) : null
  }
</Layout>
