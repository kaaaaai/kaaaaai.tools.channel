---
import { Icon } from 'astro-icon/components'

const footerClass =
  'hidden max-w-full overflow-hidden rounded-[10px] border border-dashed border-line/80 bg-white/35 px-4 py-3 text-[0.78rem] font-medium leading-none text-footer/85 md:flex md:items-center md:gap-2'
---

<footer class={footerClass}>
  <Icon name="ri:flashlight-line" class="h-4 w-4 shrink-0 text-muted/75" aria-hidden="true" />
  Powered by
  <a
    href="https://github.com/miantiao-me/BroadcastChannel"
    title="BroadcastChannel"
    target="_blank"
    rel="noopener noreferrer"
  >
    BroadcastChannel
  </a>
</footer>
