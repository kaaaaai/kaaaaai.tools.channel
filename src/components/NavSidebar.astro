---
import { Icon } from 'astro-icon/components'
import type { NavItem } from '../types'
import SearchForm from './SearchForm.astro'
import SiteFooter from './SiteFooter.astro'

const {
  channelTitle,
  currentPathname,
  googleSearchSite,
  linksPathname,
  navs = [],
  searchAction,
  showLinks,
  showTags,
  siteRootPathname,
  siteUrl,
  tagsPathname,
} = Astro.props as {
  channelTitle?: string
  currentPathname: string
  googleSearchSite?: string
  linksPathname: string
  navs?: NavItem[]
  searchAction: string
  showLinks?: boolean
  showTags?: boolean
  siteRootPathname: string
  siteUrl: string
  tagsPathname: string
}

const asideInnerClass = 'lg:max-h-[calc(100svh-3rem)] lg:overflow-y-auto'
const navClass = 'min-w-0'
const navListClass = 'm-0 list-none pl-0'
const navItemClass = 'mb-1.5 flex items-center text-sm leading-none'
const navLinkClass =
  'inline-flex min-h-11 flex-1 items-center gap-2 rounded-[10px] px-4 py-2 text-[0.92rem] font-semibold text-muted no-underline transition-colors duration-150 hover:bg-violet-soft hover:text-violet hover:no-underline'
const navLinkCurrentClass = 'bg-violet-soft text-violet'
const sectionTitleClass =
  'mb-3 flex items-center gap-2 text-[0.68rem] font-bold uppercase tracking-[0.22em] text-muted/70 before:block before:h-1.5 before:w-1.5 before:rounded-full before:bg-violet'

const primaryNavItems = [
  {
    href: siteUrl,
    pathname: siteRootPathname,
    title: 'Home',
  },
  showTags && {
    href: `${siteUrl}tags`,
    pathname: tagsPathname,
    title: 'Tags',
  },
  showLinks && {
    href: `${siteUrl}links`,
    pathname: linksPathname,
    title: 'Links',
  },
].filter((item): item is { href: string; pathname: string; title: string } => Boolean(item))
---

<div class={asideInnerClass}>
  <nav class={navClass} aria-label="Primary navigation">
    <div class={sectionTitleClass}>Navigate</div>
    <ul class={navListClass}>
      {
        primaryNavItems.map((nav) => (
          <li class={navItemClass}>
            <a
              href={nav.href}
              title={nav.title === 'Home' ? channelTitle : nav.title}
              class:list={[navLinkClass, currentPathname === nav.pathname && navLinkCurrentClass]}
            >
              {nav.title === 'Home' ? <Icon name="ri:home-5-line" class="h-4 w-4 shrink-0" aria-hidden="true" /> : null}
              {nav.title}
            </a>
          </li>
        ))
      }
      {
        navs.map((nav) => (
          <li class={navItemClass}>
            <a href={nav.href} title={nav.title} target="_blank" rel="noopener noreferrer" class={navLinkClass}>
              {nav.title}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <div class="mt-5">
    <div class={sectionTitleClass}>Search</div>
    <SearchForm action={searchAction} googleSearchSite={googleSearchSite} />
  </div>
  <div class="mt-6">
    <SiteFooter />
  </div>
</div>
